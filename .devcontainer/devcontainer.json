{
    "name": "sldm-devcontainer",
    "image": "mylib/sldm-devcont-img",
    "workspaceFolder": "/work",
    "workspaceMount": "source=${localWorkspaceFolder},target=/work,type=bind",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools",
                "ms-vscode.cmake-tools"
            ]
        }
    },
    "shutdownAction": "stopContainer"
}